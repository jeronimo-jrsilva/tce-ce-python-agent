# --- CONFIGURAÇÕES DE IA ---
# Se usar OpenAI: Insira sua chave (sk-...)
# Se usar Ollama: Pode manter "ollama" ou qualquer valor
OPENAI_API_KEY=sua_chave_aqui

# Modelo a ser utilizado (Ex: gpt-4o, gpt-3.5-turbo, llama3.1)
LLM_MODEL=llama3.1

# URL base para API (Deixe vazio para OpenAI oficial ou use http://localhost:11434/v1 para Ollama)
OPENAI_API_BASE=http://localhost:11434/v1

# --- CONFIGURAÇÕES DO SISTEMA ---
# URL da Base de Conhecimento oficial do desafio
KB_URL=https://raw.githubusercontent.com/igortce/python-agent-challenge/refs/heads/main/python_agent_knowledge_base.md

# Ativa logs detalhados no terminal
DEBUG=True
